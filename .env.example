# Variaveis de ambiente do Carrossel Studio (S3). Copie para .env.local e
# preencha com os valores reais. NUNCA commitar .env.local (ja no .gitignore).

# --- Banco (Postgres self-hosted na VPS, via PgBouncer) ----------------------
# Conexao POOLED — usada pelo runtime da app (driver pg, PgBouncer :6432).
DATABASE_URL=
# Conexao DIRETA (unpooled) — usada SO por migrations (drizzle-kit, :5432).
DATABASE_URL_UNPOOLED=
# CA pinado do Postgres (conteudo PEM), so necessario onde nao ha filesystem
# persistente (Vercel). Deixe vazio em dev local — cai para certs/db-ca.pem.
DB_CA_CERT=

# --- Auth.js (sessao JWT) ----------------------------------------------------
# Segredo de assinatura do JWT de sessao. Gere com: npx auth secret
AUTH_SECRET=

# --- MinIO / S3 (storage de imagens self-hosted; substitui o Vercel Blob) ----
# Endpoint da API S3 (URL completa, usado pelo SDK pra assinar a presigned PUT).
S3_ENDPOINT=
# Host publico onde os objetos ficam acessiveis (sem esquema).
S3_PUBLIC_HOST=
# Nome do bucket.
S3_BUCKET=
# Regiao (MinIO exige um valor; nao e AWS real, ex.: us-east-1).
S3_REGION=
# Credenciais S3 (segredo — nunca commitar valor).
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- Claude API (geracao de carrossel com IA — S5) ---------------------------
# Chave da Anthropic (billing ativo). Validacao LAZY: NAO entra no envSchema do
# boot — o app roda sem ela. Lida so quando a geracao roda; ausente => erro
# tratavel na tela de geracao (sem derrubar o resto do app). Nunca commitar valor.
ANTHROPIC_API_KEY=

# --- Seed (script db:seed — nao usadas em runtime) ---------------------------
# Credenciais do usuario admin criado pelo seed. Obrigatorias para db:seed.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# --- Provisionamento de cliente (script client:create — nao usadas em runtime) ---
# Cria uma conta de cliente (user + identidade padrao). CLIENT_EMAIL/CLIENT_PASSWORD
# sao obrigatorios; CLIENT_NAME/CLIENT_HANDLE sao opcionais (editaveis em /settings).
# Passe inline no comando (nao precisa commitar): npm run client:create
CLIENT_EMAIL=
CLIENT_PASSWORD=
CLIENT_NAME=
CLIENT_HANDLE=
